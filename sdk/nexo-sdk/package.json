{
  "name": "@luzia/nexo-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "default": "./dist/react.js"
    },
    "./src/theme.css": "./src/theme.css",
    "./theme.css": "./src/theme.css",
    "./src/shell.css": "./src/shell.css",
    "./shell.css": "./src/shell.css",
    "./src/chat.css": "./src/chat.css",
    "./chat.css": "./src/chat.css",
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "express": ">=4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
