# OpenClaw bridge webhook example env
# Copy to .env and fill values for your environment.

PORT=8082

# Bridge inbound security (Nexo -> bridge)
WEBHOOK_SECRET=change-me-webhook-secret
BRIDGE_ACCESS_KEY=change-me-bridge-access-key

# OpenClaw upstream target (bridge -> OpenClaw)
OPENCLAW_BASE_URL=https://your-openclaw-domain.example/openclaw
OPENCLAW_AGENT_ID=main
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-gateway-token

# OpenClaw origin hardening header expected by reverse proxy (Caddy/Cloudflare)
OPENCLAW_ORIGIN_HEADER_NAME=X-Nexo-Bridge-Key
OPENCLAW_ORIGIN_HEADER_VALUE=change-me-openclaw-origin-key

# Optional flexibility flags
ALLOW_REQUEST_SESSION_KEY=false
ALLOW_REQUEST_OPENCLAW_TOKEN=false
