# Partner webhook examples — environment variables
# Copy this file to .env and fill in values as needed.
# All fields are optional for local development.
#
# For Cloud Run deployment, these secrets must also exist in Secret Manager:
#   WEBHOOK_SECRET         — HMAC signing secret (shared with Nexo)
#   OPENAI_API_KEY         — OpenAI API key
#   FOOTBALL_DATA_API_KEY  — football-data.org key (sports-rag only)
#
# Create them with:
#   echo -n "value" | gcloud secrets create SECRET_NAME --data-file=-
#   gcloud secrets add-iam-policy-binding SECRET_NAME \
#     --member="serviceAccount:$(gcloud projects describe $PROJECT --format='value(projectNumber)')-compute@developer.gserviceaccount.com" \
#     --role="roles/secretmanager.secretAccessor"

# ── LLM / Embeddings ──────────────────────────────────────────────────────────
# litellm model string. Defaults to local Ollama (no API key needed).
# To use OpenAI: set LLM_MODEL=gpt-4o and fill OPENAI_API_KEY below.
LLM_MODEL=ollama/llama3.2

# OpenAI API key — required only when using OpenAI models
OPENAI_API_KEY=

# Ollama server URL — defaults to host machine when running in Docker
OLLAMA_API_BASE=http://host.docker.internal:11434

# ── Security ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret shared with Nexo dashboard.
# Leave empty to skip signature verification (fine for local dev).
WEBHOOK_SECRET=
