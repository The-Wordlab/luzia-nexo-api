# Partner webhook examples — environment variables
# Copy this file to .env and fill in values as needed.
# All fields are optional for local development.

# ── LLM / Embeddings ──────────────────────────────────────────────────────────
# litellm model string. Defaults to local Ollama (no API key needed).
# To use OpenAI: set LLM_MODEL=gpt-4o and fill OPENAI_API_KEY below.
LLM_MODEL=ollama/llama3.2

# Embedding model used by the RAG services (news-rag, sports-rag).
# text-embedding-3-small requires OPENAI_API_KEY.
# For a fully local setup: set EMBEDDING_MODEL=ollama/nomic-embed-text
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API key — required only when using OpenAI models
OPENAI_API_KEY=

# Ollama server URL — defaults to host machine when running in Docker
OLLAMA_API_BASE=http://host.docker.internal:11434

# ── Security ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret shared with Nexo dashboard.
# Leave empty to skip signature verification (fine for local dev).
WEBHOOK_SECRET=

# ── News RAG ──────────────────────────────────────────────────────────────────
# Comma-separated RSS feed URLs. Leave empty to use the built-in defaults.
NEWS_FEEDS=

# How often (minutes) the news-rag service re-crawls its feeds.
REFRESH_INTERVAL_MINUTES=30

# Number of chunks to retrieve per query.
TOP_K=5

# ── Sports RAG ────────────────────────────────────────────────────────────────
# Comma-separated sports RSS feed URLs. Leave empty to use built-in defaults.
SPORT_FEEDS=

# football-data.org API key for live match results (optional, free tier available).
FOOTBALL_DATA_API_KEY=

# Comma-separated competition IDs (e.g. PL,PD,BL1). Default: PL (Premier League).
FOOTBALL_DATA_COMPETITION=PL

# ── Travel RAG ─────────────────────────────────────────────────────────────
# Comma-separated travel RSS feed URLs. Leave empty to use built-in defaults.
TRAVEL_FEEDS=

# Enable SSE streaming for travel-rag responses (default: false).
STREAMING_ENABLED=false
