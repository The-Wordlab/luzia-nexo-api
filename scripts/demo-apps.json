                  "app_id": "search-step",
                  "input_mapping": {
                    "query": "initial_input"
                  },
                  "timeout_seconds": 15
                },
                {
                  "app_id": "confirm-step",
                  "input_mapping": {
                    "selection": "step_0_output"
                  },
                  "timeout_seconds": 15
                },
                {
                  "app_id": "execute-step",
                  "input_mapping": {
                    "confirmation": "step_1_output"
                  },
                  "timeout_seconds": 15
                }
              ],
              "created_at": "2026-01-01T00:00:00Z"
