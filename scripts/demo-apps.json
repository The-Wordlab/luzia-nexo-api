    {
      "demo_key": "chain-demo",
      "name": "Chain Demo",
      "description": "Multi-step chained experience: search -> confirm -> execute",
      "config_json": {
        "demo_key": "chain-demo",
        "integration_mode": "simulator",
        "simulator_type": "generic",
        "disclaimer": false,
        "chaining": {
          "enabled": true,
          "default_chain_id": "restaurant-chain",
          "chains": [
            {
              "chain_id": "restaurant-chain",
              "name": "Restaurant Booking",
              "description": "Search, confirm, and book a restaurant",
              "steps": [
                {
                  "app_id": "search-step",
                  "input_mapping": {
                    "query": "initial_input"
                  },
                  "timeout_seconds": 15
                },
                {
                  "app_id": "confirm-step",
                  "input_mapping": {
                    "selection": "step_0_output"
                  },
                  "timeout_seconds": 15
                },
                {
                  "app_id": "execute-step",
                  "input_mapping": {
                    "confirmation": "step_1_output"
                  },
                  "timeout_seconds": 15
                }
              ],
              "created_at": "2026-01-01T00:00:00Z"
            }
          ]
        },
        "demo_icon": "link",
        "demo_color": "#EC4899",
        "demo_order": 10,
        "prompt_suggestions": [
          "Find a sushi restaurant for 2 tonight at 8pm",
          "Book the best-rated Italian place nearby",
          "Find family-friendly lunch options within 20 minutes"
        ]
